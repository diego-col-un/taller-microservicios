# ─────────────────────────────────────────
# MICROSERVICIO PRODUCTOS - Flask + Firebase
# ─────────────────────────────────────────

# Entorno de ejecucion (development / production)
FLASK_ENV=development

# Puerto del microservicio (no cambiar, el Gateway apunta aqui)
FLASK_PORT=5000

# Ruta al archivo de credenciales de Firebase
# 1. Ve a Firebase Console -> Configuracion del proyecto -> Cuentas de servicio
# 2. Click en "Generar nueva clave privada"
# 3. Renombra el archivo descargado a firebase-key.json
# 4. Coloca firebase-key.json en la carpeta microservicio-productos/
FIREBASE_CREDENTIALS=firebase-key.json

# URL de Firebase Realtime Database
# Encontrarla en: Firebase Console -> Realtime Database -> (URL arriba de los datos)
# Formato esperado: https://NOMBRE-PROYECTO-default-rtdb.firebaseio.com/
FIREBASE_DB_URL=https://tu-proyecto-default-rtdb.firebaseio.com/